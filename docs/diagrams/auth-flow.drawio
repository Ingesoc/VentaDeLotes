        </mxCell>

        <!-- 8. RPC → checkAdmin (true/false) -->
        <mxCell id="step8" value="8. true / false" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#3ECF8E;strokeWidth=2;fontSize=10;fontFamily=Inter;fontColor=#2BA06E;dashed=1;" edge="1" parent="1" source="supabase-rpc" target="check-admin">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 9. Guard → AdminLayout -->
        <mxCell id="step9" value="9a. ✅ Es admin" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1B4332;strokeWidth=2;fontSize=10;fontFamily=Inter;fontColor=#1B4332;" edge="1" parent="1" source="admin-guard" target="result-dashboard">
          <mxGeometry relative="1" as="geometry" />
