        <!-- 2. LoginPage → AuthProvider.login() -->
        <mxCell id="step2" value="2. login(email, password)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#D4A373;strokeWidth=2;fontSize=10;fontFamily=Inter;fontColor=#7A532A;" edge="1" parent="1" source="login-page" target="auth-provider">
