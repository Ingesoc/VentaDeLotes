        <!-- 5. Navegación a admin/dashboard -->
        <mxCell id="step5" value="5. Navega a /admin/dashboard" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1B4332;strokeWidth=2;fontSize=10;fontFamily=Inter;fontColor=#1B4332;" edge="1" parent="1" source="login-page" target="admin-guard">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 6. AdminGuard → checkAdmin -->
        <mxCell id="step6" value="6. user.email" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#D4A373;strokeWidth=2;fontSize=10;fontFamily=Inter;fontColor=#7A532A;" edge="1" parent="1" source="admin-guard" target="check-admin">
