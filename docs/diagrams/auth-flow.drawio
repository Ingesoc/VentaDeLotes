          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 4. Supabase → AuthProvider → LoginPage (session) -->
        <mxCell id="step4" value="4. { user, session }" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#3ECF8E;strokeWidth=2;fontSize=10;fontFamily=Inter;fontColor=#2BA06E;dashed=1;" edge="1" parent="1" source="supabase-auth" target="auth-provider">
