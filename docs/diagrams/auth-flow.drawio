        <!-- 1. Usuario → LoginPage -->
        <mxCell id="step1" value="1. Ingresa email + password" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#1B4332;strokeWidth=2;fontSize=10;fontFamily=Inter;fontColor=#1B4332;" edge="1" parent="1" source="actor-usuario" target="login-page">
