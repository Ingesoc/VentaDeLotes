+          Lote {lot.id}
+        </h3>
+        <p className="text-body-md font-body-md text-on-surface-variant flex items-center gap-2 mb-6 flex-grow">
+          <Ruler className="w-4 h-4" />
+          {lot.areaM2
+            ? `${lot.areaM2.toLocaleString("es-CO")} m²`
